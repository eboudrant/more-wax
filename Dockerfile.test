FROM mcr.microsoft.com/playwright:v1.59.0-noble@sha256:11707c5282fec52f0705aad3a23f46b3409b3de4aed378b3dbe118d8b8c87b67

# Add Python for the backend server
RUN apt-get update \
    && apt-get install -y --no-install-recommends python3 python3-venv openssl ffmpeg \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Install Node dependencies first (cacheable layer)
COPY package.json ./
RUN npm install

# Copy app source
COPY . .

# Ensure data dir exists
RUN mkdir -p data/covers

# Default: run screenshot tests
CMD ["npx", "playwright", "test"]
